# {{ ansible_managed }}
# Global SSH Configuration
# Managed by Ansible - DO NOT EDIT MANUALLY
#
# Generated: {{ ansible_date_time.iso8601 }}
# Host: {{ inventory_hostname }}

# Include modular configs
{% if ssh_manage_config_d %}
Include {{ ssh_config_dir }}/*
{% endif %}

# Global settings (apply to all hosts)
Host *
{% for key, value in ssh_global_config.items() %}
    {{ key }} {{ value }}
{% endfor %}
    # Security hardening
    PasswordAuthentication no
    ChallengeResponseAuthentication no
    GSSAPIAuthentication no
    # Modern crypto
    HostKeyAlgorithms ssh-ed25519,ssh-ed25519-cert-v01@openssh.com,rsa-sha2-512,rsa-sha2-256
    PubkeyAcceptedAlgorithms ssh-ed25519,ssh-ed25519-cert-v01@openssh.com,rsa-sha2-512,rsa-sha2-256
    KexAlgorithms curve25519-sha256,curve25519-sha256@libssh.org,diffie-hellman-group16-sha512,diffie-hellman-group18-sha512
    Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com,aes256-ctr
    MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com,umac-128-etm@openssh.com
