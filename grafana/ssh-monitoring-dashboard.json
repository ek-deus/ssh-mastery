{
  "dashboard": {
    "id": null,
    "uid": "ssh-monitoring-dark",
    "title": "🔐 SSH Security Monitoring",
    "tags": ["ssh", "security", "devops"],
    "timezone": "browser",
    "editable": true,
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "theme": "dark",
    "panels": [
      {
        "id": 1,
        "title": "🔥 Active SSH Sessions",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "ssh_active_sessions_total",
            "legendFormat": "{{instance}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 5},
                {"color": "red", "value": 10}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "⚠️ Failed Auth Attempts (5m)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(ssh_auth_failures_total[5m])) * 300",
            "legendFormat": "Failures"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "orange", "value": 10},
                {"color": "red", "value": 50}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "🚨 Brute-force IPs Detected",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "count(ssh_bruteforce_detected_ips > 0)",
            "legendFormat": "Attacking IPs"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "red", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "✅ Successful Auth (5m)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(ssh_auth_attempts_total{status=\"success\"}[5m])) * 300",
            "legendFormat": "Success"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "fixed", "fixedColor": "green"}
          }
        }
      },
      {
        "id": 5,
        "title": "📊 Authentication Attempts Over Time",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "sum(rate(ssh_auth_attempts_total{status=\"success\"}[5m])) * 300",
            "legendFormat": "✅ Success"
          },
          {
            "expr": "sum(rate(ssh_auth_attempts_total{status=\"failure\"}[5m])) * 300",
            "legendFormat": "❌ Failure"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 20,
              "lineWidth": 2
            }
          }
        }
      },
      {
        "id": 6,
        "title": "🌍 Top Attacking IPs",
        "type": "bargauge",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "topk(10, sum by (ip) (ssh_auth_failures_by_ip))",
            "legendFormat": "{{ip}}",
            "format": "table"
          }
        ],
        "options": {
          "orientation": "horizontal",
          "displayMode": "gradient"
        },
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "continuous-GrYlRd"}
          }
        }
      },
      {
        "id": 7,
        "title": "👥 Active Sessions by User",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "ssh_active_sessions_by_user",
            "legendFormat": "{{user}}"
          }
        ]
      },
      {
        "id": 8,
        "title": "🔑 Auth Methods Used",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 12},
        "targets": [
          {
            "expr": "sum by (method) (ssh_auth_attempts_total{status=\"success\"})",
            "legendFormat": "{{method}}"
          }
        ]
      },
      {
        "id": 9,
        "title": "🚫 Top Invalid Usernames Attempted",
        "type": "table",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 12},
        "targets": [
          {
            "expr": "topk(10, sum by (username) (ssh_invalid_usernames_top))",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true},
              "renameByName": {
                "username": "Username",
                "Value": "Attempts"
              }
            }
          }
        ]
      },
      {
        "id": 10,
        "title": "🔐 Root Login Attempts",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 20},
        "targets": [
          {
            "expr": "rate(ssh_root_login_attempts_total[5m]) * 300",
            "legendFormat": "Root attempts"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "fixed", "fixedColor": "red"},
            "custom": {
              "drawStyle": "bars",
              "fillOpacity": 50
            }
          }
        }
      },
      {
        "id": 11,
        "title": "⏱️ Average Session Duration",
        "type": "gauge",
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 20},
        "targets": [
          {
            "expr": "ssh_session_duration_seconds",
            "legendFormat": "Duration"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 3600},
                {"color": "red", "value": 86400}
              ]
            }
          }
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "instance",
          "type": "query",
          "query": "label_values(ssh_active_sessions_total, instance)",
          "refresh": 2,
          "multi": true,
          "includeAll": true
        }
      ]
    }
  }
}
